pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	pi = 3.1415
	b = nil
	bullets = {}
	b = load_boss(63,63)
	b.a1(b.x, b.y, 16)
end

function _update()
	if t() % 2 == 0 then
		b.a1(b.x, b.y,16)
	end
	foreach(bullets,  bullet_move)
end

function _draw()
	cls()
	spr(b.sprite, b.x-b.w/2, b.y-b.h/2, 2,2)
	
	-- center
	pset(63,63, 8)
	
	foreach(bullets, bullet_draw)
end

-- first boss

function load_boss(x,y)
	local boss = {
		x=x, y=y,
		h=16, w=16,
		sprite=1,
		details=4,
		level=1,
		a1 = basic_atack
	}
	return boss
end

function basic_atack(x,y,n)
	local angle_deg, angle_rad=0
	local bx, by, dx, dy=0
	local radius = 8
	
	for i=0,n do
		angle_deg = i / n * 360
		angle_rad = angle_deg * pi/180
		dx = cos(angle_rad)
		dy = sin(angle_rad)
		bx = x-2 + dx * radius
		by = y-2 + dy * radius
		
		bullet_create(bx,by,dx,dy)
	end
end

function bullet_create(x,y,dx,dy)
	add(bullets, {
			x=x,   y=y,
			dx=dx, dy=dy,
			w=4, h=4,
			sprite=3,
		}
	)
end

function bullet_move(b)
	b.x += b.dx
	b.y += b.dy
	if  b.x > 128 or b.x < 0 or
		   b.y > 128 or b.y < 0
	then
		del(bullets, b)
	end
end

function bullet_draw(b)
	spr(b.sprite,b.x,b.y)
end
